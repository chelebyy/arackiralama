# Dokploy / Docker Compose
DOKPLOY_NETWORK=dokploy-network
API_PORT=8080
WEB_PORT=3000

# PostgreSQL
POSTGRES_DB=rentacar
POSTGRES_USER=rentacar
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=Host=postgres;Port=5432;Database=rentacar;Username=rentacar;Password=change-this-postgres-password
DATABASE_AUTO_MIGRATE_ON_STARTUP=true

# Redis
REDIS_PASSWORD=change-this-redis-password
REDIS_CONNECTION_STRING=redis:6379,password=change-this-redis-password

# API / JWT
JWT_ISSUER=RentACar.API
JWT_AUDIENCE=RentACar.Client
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Frontend public URLs
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com/api
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Frontend server-to-server auth URL
AUTH_BACKEND_URL=http://api:8080
AUTH_ACCESS_COOKIE_NAME=rac_access
AUTH_REFRESH_COOKIE_NAME=__Host-rac_refresh

# Optional analytics
GA_KEY=
