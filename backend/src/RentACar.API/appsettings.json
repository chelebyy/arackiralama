{
    "ConnectionStrings":  {
                              "DefaultConnection":  "Host=localhost;Port=5433;Database=rentacar;Username=postgres;Password=postgres"
                          },
    "Redis":  {
                  "ConnectionString":  "localhost:6379"
              },
    "Jwt":  {
                "Issuer":  "RentACar.API",
                "Audience":  "RentACar.Client",
                "Secret":  "CHANGE_THIS_TO_A_32_CHAR_MINIMUM_SECRET",
                "AccessTokenMinutes":  15,
                "RefreshTokenDays":  7
            },
    "Auth":  {
                 "RefreshTokenCookie":  {
                                            "Name":  "__Host-rac_refresh",
                                            "Path":  "/",
                                            "SameSite":  "Strict",
                                            "SecurePolicy":  "Always",
                                            "HttpOnly":  true,
                                            "IsEssential":  true
                                        }
             },
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "AllowedHosts":  "*",
    "Database":  {
                     "AutoMigrateOnStartup":  true
                 },
    "Payment":  {
                    "Provider":  "Mock",
                    "Currency":  "TRY",
                    "IntentExpiresMinutes":  15,
                    "RetryLimit":  3,
                    "TimeoutRetryCount":  2,
                    "WebhookJobBatchSize":  20,
                    "Mock":  {
                                 "WebhookSecret":  "mock-webhook-secret"
                             },
                    "Iyzico":  {
                                   "ApiKey":  "",
                                   "SecretKey":  "",
                                   "BaseUrl":  "https://sandbox-api.iyzipay.com",
                                   "WebhookSecret":  ""
                               }
                 }
}
