{
    "Jwt":  {
                "Issuer":  "RentACar.API",
                "Audience":  "RentACar.Client",
                "Secret":  "DevelopmentOnlySecretKeyAtLeast32Chars",
                "AccessTokenMinutes":  15,
                "RefreshTokenDays":  7
            },
    "Auth":  {
                 "RefreshTokenCookie":  {
                                            "Name":  "rac_refresh",
                                            "Path":  "/",
                                            "SameSite":  "Strict",
                                            "SecurePolicy":  "SameAsRequest",
                                            "HttpOnly":  true,
                                            "IsEssential":  true
                                        }
             },
    "Cors":  {
                 "AllowedOrigins":  [
                                        "http://localhost:3000",
                                        "http://127.0.0.1:3000",
                                        "http://localhost:3001",
                                        "http://127.0.0.1:3001"
                                    ]
             },
    "Notifications":  {
                          "PublicFrontendBaseUrl":  "http://localhost:3001"
                      },
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "Database":  {
                     "AutoMigrateOnStartup":  true
                 }
}
